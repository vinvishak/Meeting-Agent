# Jira MCP Server
JIRA_MCP_URL=http://localhost:3000
JIRA_MCP_TOKEN=your-jira-mcp-token-here

# Copilot MCP Server
COPILOT_MCP_URL=http://localhost:3001
COPILOT_MCP_TOKEN=your-copilot-mcp-token-here

# Claude API (for NL queries and semantic embedding matching)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# Sync settings
SYNC_INTERVAL_MINUTES=15
STALE_THRESHOLD_DAYS=10
# Comma-separated Jira project/board keys to sync (e.g. PROJ,INFRA,PLAT)
JIRA_PROJECT_KEYS=

# Update suggestion thresholds
HIGH_CONFIDENCE_THRESHOLD=0.90
AUTO_APPLY_ENABLED=false

# Logging
LOG_LEVEL=INFO
